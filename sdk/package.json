{
  "name": "@stendar-x/sdk",
  "version": "0.6.27",
  "description": "TypeScript SDK for the Stendar protocol",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!dist/__tests__",
    "!dist/__tests__/**",
    "!dist/**/*.js.map"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "rm -rf dist dist-tests",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test dist-tests/__tests__/*.test.js"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
