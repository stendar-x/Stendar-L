{
  "name": "stendar-protocol",
  "private": true,
  "license": "MIT",
  "scripts": {
    "test": "npm run test:regression",
    "test:ci": "npm run test:security-scripts && npm run test:pending:deterministic && npm run test:regression && npm run idl:check:if-present && npm run audit:gate",
    "test:devnet:full": "ANCHOR_PROVIDER_URL=https://api.devnet.solana.com ANCHOR_WALLET=~/.config/solana/id.json ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.ts",
    "test:devnet": "ANCHOR_PROVIDER_URL=https://api.devnet.solana.com ANCHOR_WALLET=~/.config/solana/id.json npx ts-mocha -p ./tsconfig.json -t 120000 tests/pool_lifecycle.ts",
    "test:revolving": "ANCHOR_PROVIDER_URL=https://api.devnet.solana.com ANCHOR_WALLET=~/.config/solana/id.json ts-mocha -p ./tsconfig.json -t 1000000 tests/revolving_lifecycle.ts",
    "test:regression": "npx ts-mocha --forbid-pending --forbid-only -p ./tsconfig.json -t 120000 tests/trading.ts tests/integration_trading.ts tests/security_regression_static.ts tests/platform_stats_service.ts",
    "test:pending:deterministic": "node ./scripts/check-deterministic-pending.js",
    "idl:check": "node ./scripts/check-idl-sync.js",
    "idl:check:if-present": "node ./scripts/check-idl-sync.js --if-present",
    "collateral:listings:check": "node ./scripts/validate-collateral-listings.js",
    "test:security-scripts": "node --test scripts/__tests__/*.test.js",
    "audit:gate": "npm run collateral:listings:check && node ./scripts/audit-gate.js",
    "sdk:build": "npm --prefix sdk run build",
    "sdk:test": "npm --prefix sdk test",
    "sdk:publish": "npm --prefix sdk publish"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "0.31.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.40",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "chai": "^4.5.0",
    "mocha": "^11.7.5",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
